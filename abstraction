// Step 1: Abstract class
abstract class Animal {

    // Step 2: Abstract method (no body)
    abstract void sound();

    // Concrete method (with body)
    void sleep() {
        System.out.println("Animal is sleeping...");
    }
}

// Step 3: Subclass
class Dog extends Animal {

    // Providing implementation of abstract method
    void sound() {
        System.out.println("Dog barks");
    }
}

// Main class
public class Main {
    public static void main(String[] args) {

        // Step 4: Create object of subclass
        Dog d = new Dog();

        // Calling methods
        d.sound();   // abstract method implemented
        d.sleep();   // concrete method from abstract class
    }
}
